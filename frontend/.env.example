# Frontend environment variables (Vite reads VITE_* prefixed vars).
# Copy to .env.local for dev overrides. .env files are gitignored.

# Base URL of the Support Orchestrator API.
# - Leave unset to use the dev-server proxy at /api/v1/* -> localhost:8000
# - Set to e.g. "https://api.example.com" for a deployed environment
VITE_API_BASE_URL=
