# =============================================================================
# Support Orchestrator — local environment (gitignored). Never commit.
# =============================================================================

# ---- LLM provider selection -------------------------------------------------
# One of: openai | anthropic | gemini | mock
LLM_PROVIDER=openai

# ---- OpenAI (via DashScope OpenAI-compatible endpoint, Alibaba Qwen) --------
OPENAI_API_KEY=
OPENAI_MODEL=qwen-plus
OPENAI_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# ---- Google Gemini (unused while LLM_PROVIDER=openai; kept for easy switch)--
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# ---- Anthropic (unused) -----------------------------------------------------
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# ---- Orchestration tuning ---------------------------------------------------
MAX_RETRIES=2
REQUEST_TIMEOUT_SECONDS=30

# ---- App --------------------------------------------------------------------
APP_VERSION=0.1.0
LOG_LEVEL=INFO
LOG_FORMAT=json

# Comma-separated CORS origins. "*" allowed for the assessment.
CORS_ORIGINS=*
