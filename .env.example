# =============================================================================
# Support Orchestrator — environment configuration template
# Copy to `.env` and fill in real values. Never commit `.env`.
# =============================================================================

# ---- LLM provider selection -------------------------------------------------
# One of: openai | anthropic | gemini | mock
#
# Free-tier guide:
#   - gemini  : 1500 free requests/day on gemini-2.0-flash. Recommended for
#               assessments and local dev. Get a free key at
#               https://aistudio.google.com/
#   - mock    : deterministic canned responses (no API key, no network)
#   - openai  : paid (gpt-4o-mini ~ $0.15/1M input tokens)
#   - anthropic: paid (claude-sonnet-4-5 ~ $3/1M input tokens)
LLM_PROVIDER=gemini

# ---- Google Gemini (free tier) ----------------------------------------------
# Required when LLM_PROVIDER=gemini. Free key from
# https://aistudio.google.com/  ->  "Get API key"
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ---- OpenAI -----------------------------------------------------------------
# Required when LLM_PROVIDER=openai.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# OPTIONAL: point the OpenAI SDK at any OpenAI-compatible base URL. This lets
# you use Groq (free tier!) without writing a new provider:
#   LLM_PROVIDER=openai
#   OPENAI_API_KEY=<your groq key from https://console.groq.com/keys>
#   OPENAI_MODEL=llama-3.3-70b-versatile
#   OPENAI_BASE_URL=https://api.groq.com/openai/v1
# Note: Groq supports OpenAI's tool-calling but NOT its strict structured-
# outputs (`parse()`) mode. Some Pydantic-schema constraints may be rejected.
# Test with `make demo` first; if it errors, fall back to LLM_PROVIDER=gemini.
OPENAI_BASE_URL=

# ---- Anthropic --------------------------------------------------------------
# Required when LLM_PROVIDER=anthropic.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# ---- Orchestration tuning ---------------------------------------------------
MAX_RETRIES=2
REQUEST_TIMEOUT_SECONDS=30

# ---- App ---------------------------------------------------------------------
APP_VERSION=0.1.0
LOG_LEVEL=INFO
# json (production) | console (local dev pretty print)
LOG_FORMAT=json

# Comma-separated origins for CORS. "*" allowed for the assessment;
# tighten in production (see ARCHITECTURE.md).
CORS_ORIGINS=*
