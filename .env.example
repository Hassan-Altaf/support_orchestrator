# =============================================================================
# Support Orchestrator — environment configuration template
# Copy to `.env` and fill in real values. Never commit `.env`.
# =============================================================================

# ---- LLM provider selection -------------------------------------------------
# One of: openai | anthropic | mock
LLM_PROVIDER=openai

# Required when LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Required when LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# ---- Orchestration tuning ---------------------------------------------------
MAX_RETRIES=2
REQUEST_TIMEOUT_SECONDS=30

# ---- App ---------------------------------------------------------------------
APP_VERSION=0.1.0
LOG_LEVEL=INFO
# json (production) | console (local dev pretty print)
LOG_FORMAT=json

# Comma-separated origins for CORS. "*" allowed for the assessment;
# tighten in production (see ARCHITECTURE.md).
CORS_ORIGINS=*
